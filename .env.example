# Copy to .env (or export as real environment variables) before running in prod

# ---- App ----
SPRING_PROFILES_ACTIVE=prod
SERVER_PORT=8080

# ---- Security ----
# MUST be at least 32 characters. Generate one with:
#   openssl rand -base64 48
JWT_SECRET=change-me-to-a-long-random-secret-value-at-least-32-characters
JWT_EXPIRATION_MINUTES=60

# ---- Database (used only when SPRING_PROFILES_ACTIVE=prod) ----
DB_HOST=localhost
DB_PORT=5432
DB_NAME=aigateway
DB_USER=aigateway
DB_PASSWORD=aigateway

# ---- AI Provider ----
# provider = openai | mock
AI_PROVIDER=openai
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
